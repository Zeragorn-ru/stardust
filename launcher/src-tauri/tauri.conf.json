{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Launcher",
  "version": "0.2.0",
  "identifier": "com.project.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Project Launcher",
        "width": 920,
        "height": 600,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5NkUxQkFDREFBODQwOEUKUldTT1FLamFyQnR1ZVNSTFh2MXFOaDNkYjZUanZKUis3OVR4N2IzVzVybXVYRk1XUjdWU0VabTcK",
      "endpoints": [
        "https://github.com/Zeragorn-ru/stardust/releases/latest/download/latest.json"
      ]
    }
  }
}
