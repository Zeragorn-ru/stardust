{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StarDust",
  "version": "0.0.0",
  "identifier": "com.stardust.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "StarDust",
        "width": 1100,
        "height": 700,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://auth.zeragorn.xyz https://admin.zeragorn.xyz https://api.github.com https://resources.download.minecraft.net https://piston-meta.mojang.com https://maven.neoforged.net https://api.adoptium.net https://authlib-injector.yushi.moe; img-src 'self' data: blob: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "dmg": {}
    },
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  },
  "plugins": {}
}
