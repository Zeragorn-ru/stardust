# Шаблон окружения для бекенда лаунчера.
# Скопируй в .env рядом с docker-compose.yml и заполни значения:
#   cp .env.example .env
# Файл .env с реальными паролями в git не коммитится.

# --- PostgreSQL ---
POSTGRES_USER=launcher
# Длинный случайный пароль. Сгенерируй, напр.: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=launcher

# --- auth-server ---
# Публичный адрес, под которым сервер виден игре и лаунчеру.
# КРИТИЧНО для скинов/текстур и Yggdrasil: ставь реальный домен или IP,
# а не localhost. Для продакшена — https://... (за reverse-proxy с TLS).
AUTH_PUBLIC_URL=http://CHANGE_ME:8080

# Порт, который публикуется на хосте (наружу). Внутри контейнер всегда 8080.
AUTH_PORT=8080

# Уровень логирования auth-server.
RUST_LOG=auth_server=info

# Образ auth-server в реестре. По умолчанию latest из ghcr.io.
# Можно зафиксировать конкретный тег по sha коммита, напр.:
#   AUTH_IMAGE=ghcr.io/zeragorn-ru/stardust/auth-server:sha-<commit>
# AUTH_IMAGE=ghcr.io/zeragorn-ru/stardust/auth-server:latest
