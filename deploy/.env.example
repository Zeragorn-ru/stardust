# Скопируй в .env и поменяй пароли перед запуском.

# --- PostgreSQL ---
POSTGRES_USER=launcher
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=launcher

# --- auth-server ---
# Порт, на котором сервис доступен на хосте.
AUTH_PORT=8080
# Уровень логирования (tracing EnvFilter).
RUST_LOG=auth_server=info,tower_http=warn
