# Конфигурация бекенда лаунчера для docker-compose.
# Скопируй в .env (cp .env.example .env) и отредактируй значения.

# --- PostgreSQL (общая БД для auth-server и admin-server) ---
POSTGRES_USER=launcher
POSTGRES_PASSWORD=change-me
POSTGRES_DB=launcher

# --- auth-server ---
# Порт, на котором auth-server доступен снаружи (за TLS-прокси).
AUTH_PORT=8080
# Публичный URL, под которым сервер виден игре (текстуры, skinDomains).
# На проде — публичный https-хост за reverse-proxy.
AUTH_PUBLIC_URL=https://auth.zeragorn.xyz
# Уровень логирования auth-server.
RUST_LOG=auth_server=info
# Переопределение образа auth-server (по умолчанию latest из ghcr.io).
# AUTH_IMAGE=ghcr.io/zeragorn-ru/stardust/auth-server:latest

# --- admin-server + admin-web (админка сборок) ---
# Порт, на котором публикуется веб-админка (nginx). Единственная публичная
# точка входа для админки и для раздачи манифеста/файлов лаунчеру.
ADMIN_WEB_PORT=8082
# Публичный URL раздачи файлов — попадает в манифест, который качает лаунчер.
# Должен указывать на публичный admin-web (/files) за TLS-прокси.
FILES_BASE_URL=https://admin.zeragorn.xyz/files
# Логины (через запятую), которым при старте admin-server выдаётся роль admin.
# Нужно, чтобы выдать самого первого админа (регистрация всегда создаёт user).
# Сначала зарегистрируй логин в лаунчере, потом впиши его сюда и перезапусти.
ADMIN_BOOTSTRAP=
# Уровень логирования admin-server.
ADMIN_RUST_LOG=admin_server=info,tower_http=warn
# Переопределение образов (по умолчанию latest из ghcr.io).
# ADMIN_IMAGE=ghcr.io/zeragorn-ru/stardust/admin-server:latest
# ADMIN_WEB_IMAGE=ghcr.io/zeragorn-ru/stardust/admin-web:latest
